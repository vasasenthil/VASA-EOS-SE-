# VASA-EOS(SE)-TN pilot — copy to `.env` and edit for your district, then `docker compose up --build`.

# The district this pilot goes live for. Any valid TN tenancy district id works; the platform's
# materialised tenancy tree carries all 38 TN districts. Verified examples:
#   TN-DIST-Chennai   (default)
#   TN-DIST-Madurai
PILOT_DISTRICT=TN-DIST-Chennai

# Durable Postgres credentials (the system of record).
POSTGRES_USER=vasa
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=vasa

# Host ports.
WEB_PORT=3000
PLATFORMD_PORT=8080
